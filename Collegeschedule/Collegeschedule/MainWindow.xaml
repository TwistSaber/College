<Window x:Class="Collegeschedule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление расписанием" Height="500" Width="850"
        Background="{DynamicResource BgBrush}" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D1D1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="180"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Content="🌙"
        Width="40"
        Height="30"
        HorizontalAlignment="Right"
        Click="ToggleTheme_Click"/>

        <TextBlock Text="Расписание колледжа" FontSize="24" FontWeight="Bold" 
                   Margin="0,0,0,15" Foreground="{DynamicResource TextBrush}" Grid.ColumnSpan="2"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <DataGrid x:Name="dataGridSchedule" BorderThickness="0" Background="White" Margin="5"/>
        </Border>

        <StackPanel Grid.Column="1" Grid.Row="1" VerticalAlignment="Top">
            <Button Content="+ Добавить" Click="Add_Click" Style="{StaticResource PrimaryButton}"/>
            <Button Content="Редактировать" Click="Edit_Click" Style="{StaticResource BaseButtonStyle}"/>
            <Button Content="Удалить" Click="Delete_Click" Style="{StaticResource BaseButtonStyle}" Foreground="#C42B1C"/>
        </StackPanel>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#EBEBEB" 
                CornerRadius="8" Margin="0,15,0,0" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Фильтры:" VerticalAlignment="Center" Margin="5,0,15,0" FontWeight="SemiBold"/>

                <StackPanel Margin="5,0">
                    <TextBlock Text="Курс" FontSize="10" Foreground="Gray"/>
                    <ComboBox x:Name="comboBoxCourse" Width="80"/>
                </StackPanel>

                <StackPanel Margin="5,0">
                    <TextBlock Text="День" FontSize="10" Foreground="Gray"/>
                    <ComboBox x:Name="comboBoxDays" Width="130"/>
                </StackPanel>

                <StackPanel Margin="5,0">
                    <TextBlock Text="Группа" FontSize="10" Foreground="Gray"/>
                    <ComboBox x:Name="comboBoxGroups" Width="130"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
